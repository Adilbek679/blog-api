# Version control
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Test & coverage
.pytest_cache/
.coverage
htmlcov/

# Local environment files (injected via docker-compose env_file)
settings/.env
.env

# Development logs
logs/
*.log

# Media files (mounted as a volume)
media/

# Static files (generated by collectstatic inside container)
staticfiles/

# SQLite database (mounted as a named volume)
db.sqlite3

# Documentation
docs/

# Node (if any frontend tooling)
node_modules/

# macOS
.DS_Store

# Byte-compiled / optimized / DLL files
*.egg-info/
dist/
build/
