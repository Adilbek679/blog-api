# Blog API — Environment Variables
# Copy this file to settings/.env and fill in the values.

# Django core
BLOG_SECRET_KEY=your-secret-key-here
BLOG_DEBUG=false
BLOG_ALLOWED_HOSTS=localhost,127.0.0.1
BLOG_ENV_ID=local

# Database (leave as default for SQLite)
BLOG_DATABASE_URL=sqlite:///db.sqlite3

# Redis
BLOG_REDIS_URL=redis://redis:6379/0

# Celery (separate Redis database from cache)
BLOG_CELERY_BROKER_URL=redis://redis:6379/1

# Flower monitoring dashboard
BLOG_FLOWER_USER=admin
BLOG_FLOWER_PASSWORD=changeme

# Seed database on startup (set to true for first run)
BLOG_SEED_DB=false
