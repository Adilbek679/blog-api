# =============================================================================
#  Blog API — environment configuration (hw4)
# =============================================================================
#  Copy this file to settings/.env and fill in the secrets.
#
#  HW4 runs Django behind nginx, so the env identifier must select the prod
#  settings module (DEBUG=False).  Setting BLOG_ENV_ID=prod makes manage.py
#  load settings/env/prod.py.
# -----------------------------------------------------------------------------

# Django core
BLOG_SECRET_KEY=django-insecure-change-me-in-production
BLOG_DEBUG=false
BLOG_ALLOWED_HOSTS=localhost,127.0.0.1
BLOG_ENV_ID=prod

# PostgreSQL — `db` is the Compose service name.
BLOG_DATABASE_URL=postgres://blogapi:blogapi@db:5432/blogapi

# Redis — separate logical databases for cache, broker, and channel layer.
BLOG_REDIS_URL=redis://redis:6379/0
BLOG_CELERY_BROKER_URL=redis://redis:6379/1

# Flower basic-auth credentials (read by docker-compose.yml).
BLOG_FLOWER_USER=admin
BLOG_FLOWER_PASSWORD=admin123

# Set to `true` on the very first `docker compose up` to populate the DB
# with a superuser, sample categories, posts, and comments.  Switch back
# to `false` afterwards so subsequent boots do not re-seed.
BLOG_SEED_DB=false
